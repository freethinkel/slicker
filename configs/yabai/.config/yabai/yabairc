#!/usr/bin/env bash
# ─── Slicker yabai Config ────────────────────────────────────────────
# Base layer — managed by slicker. Personal overrides go in user/yabai/user.yabairc

# Load scripting addition
sudo yabai --load-sa
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"

# BSP layout
yabai -m config layout bsp
yabai -m config window_placement second_child
yabai -m config auto_balance on

# Statusbar — 40 on built-in (notch), 30 on external
_slicker_display_bar_height="$HOME/.config/yabai/display_bar_height.py"

_slicker_bar_height_for_display() {
  local display_id
  display_id=$(/opt/homebrew/bin/yabai -m query --displays --display "${1:+--display $1}" 2>/dev/null |
    /usr/bin/python3 -c "import sys,json; print(json.load(sys.stdin)['id'])")
  /usr/bin/python3 "$_slicker_display_bar_height" "$display_id"
}

_slicker_set_bar() {
  local h=$(_slicker_bar_height_for_display)
  yabai -m config external_bar all:"$h":0
  sketchybar --bar height="$h"
}
_slicker_set_bar

# Padding and gaps
yabai -m config top_padding 8
yabai -m config bottom_padding 8
yabai -m config left_padding 8
yabai -m config right_padding 8
yabai -m config window_gap 8

yabai -m config window_opacity on
yabai -m config active_window_opacity 1.0
yabai -m config normal_window_opacity 0.9

yabai -m config window_animation_duration 0.2
yabai -m config window_animation_easing ease_out_quint
yabai -m config window_opacity_duration 0.2

# Mouse follows focus
yabai -m config mouse_modifier ctrl
yabai -m config mouse_action1 move
yabai -m config mouse_action2 resize
yabai -m config mouse_drop_action stack

# Active window border (via JankyBorders) — accent color from theme
_slicker_accent="e1e1e1"
_slicker_colors="$HOME/.config/slicker/theme/colors.toml"
if [[ -f "$_slicker_colors" ]]; then
  _slicker_accent=$(grep '^accent' "$_slicker_colors" | sed 's/.*"#\([^"]*\)".*/\1/')
fi
borders active_color=0xff${_slicker_accent} inactive_color=0x50${_slicker_accent} width=6.0 &

# Sketchybar integration
yabai -m signal --add event=space_changed action="sketchybar --trigger space_change INFO=\$YABAI_SPACE_INDEX"
yabai -m signal --add event=window_created action="sketchybar --trigger windows_on_spaces"
yabai -m signal --add event=window_destroyed action="sketchybar --trigger windows_on_spaces"
yabai -m signal --add event=display_added action="sleep 1 && if /usr/sbin/ioreg -rc AppleBacklightDisplay &>/dev/null; then yabai -m config external_bar all:40:0; else yabai -m config external_bar all:30:0; fi && launchctl kickstart -k gui/\$(id -u)/homebrew.mxcl.sketchybar"
yabai -m signal --add event=display_removed action="sleep 1 && if /usr/sbin/ioreg -rc AppleBacklightDisplay &>/dev/null; then yabai -m config external_bar all:40:0; else yabai -m config external_bar all:30:0; fi && launchctl kickstart -k gui/\$(id -u)/homebrew.mxcl.sketchybar"
yabai -m signal --add event=display_changed action="did=\$(/opt/homebrew/bin/yabai -m query --displays --display \$YABAI_DISPLAY_INDEX | /usr/bin/python3 -c 'import sys,json; print(json.load(sys.stdin)[\"id\"])'); h=\$(/usr/bin/python3 \$HOME/.config/yabai/display_bar_height.py \$did); yabai -m config external_bar all:\$h:0; sketchybar --bar height=\$h"

# Float system apps that don't tile well
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^Finder$" manage=off title="^Copy$|^Move$|^Delete$|^Trash$"

yabai -m rule --add app="^Ghostty$" title="^scratch$" manage=off grid=6:6:2:2:2:2

# ─── User overrides ──────────────────────────────────────────────────
[[ -f ~/.config/slicker/user/yabai/user.yabairc ]] && source ~/.config/slicker/user/yabai/user.yabairc
