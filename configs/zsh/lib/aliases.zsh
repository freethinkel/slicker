# ─── Slicker Aliases ──────────────────────────────────────────────────

# ─── Better Alternatives to default cli tool ───

alias ls="eza"
alias cat="bat"

alias ll='ls -lAh'
alias l="ll"
alias la='ls -A'
alias ..='cd ..'
alias ...='cd ../..'

# Git shortcuts
alias gs='git status'
alias gd='git diff'
alias gl='git log --oneline -20'
alias gp='git pull --rebase'

alias vim="nvim"
alias cls="clear"

alias :q="exit"
alias :qa="exit"
