#!/usr/bin/env bash
set -euo pipefail

export SLICKER_DIR="$(cd "$(dirname "$0")/.." && pwd)"
source "$SLICKER_DIR/scripts/common.sh"

usage() {
  cat <<EOF
${BOLD}slicker${RESET} — opinionated macOS dotfiles framework

${BOLD}Usage:${RESET}
  slicker <command> [options]

${BOLD}Commands:${RESET}
  install              Full install (brew, stow, symlinks)
  update [--skip-user]  Pull latest + re-stow + sync new user configs
  user init [repo-url] Clone or initialize user config
  user edit            Open user/ in \$EDITOR
  theme list           List available themes
  theme set <name>     Set active theme (generates from palette)
  theme current        Show current theme
  wallpaper next       Set next wallpaper from current theme
  wallpaper set <path> Set wallpaper from file path
  status               Show link status and config info
  help                 Show this help message
EOF
}

case "${1:-}" in
install) exec "$SLICKER_DIR/scripts/install.sh" "${@:2}" ;;
update) exec "$SLICKER_DIR/scripts/update.sh" "${@:2}" ;;
theme) exec "$SLICKER_DIR/scripts/theme.sh" "${@:2}" ;;
wallpaper) exec "$SLICKER_DIR/scripts/wallpaper.sh" "${@:2}" ;;
user) exec "$SLICKER_DIR/scripts/user.sh" "${@:2}" ;;
status) exec "$SLICKER_DIR/scripts/status.sh" "${@:2}" ;;
help | --help | -h | "") usage ;;
*)
  err "Unknown command: $1"
  usage
  exit 1
  ;;
esac
